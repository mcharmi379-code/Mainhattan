export default "<div class=\"sw-cms-el-config-netzp-blog6\">\n    <sw-container columns=\"1fr 1fr 1fr 1fr\" gap=\"20px\">\n        <sw-single-select :label=\"$t('sw-cms.elements.netzp-blog6.config.category')\"\n                          :options=\"categories\" valueProperty=\"id\" labelProperty=\"title\"\n                          v-model=\"element.config.category.value\">\n            <template #selection-label-property=\"{ item }\">\n                {{ item.title || item.translated.title }}\n            </template>\n            <template #result-label-property=\"{ item }\">\n                {{ item.title || item.translated.title }}\n            </template>\n        </sw-single-select>\n\n        <sw-number-field numbertype=\"int\" :min=\"0\"\n                         :label=\"$tc('sw-cms.elements.netzp-blog6.config.numberofposts.title')\"\n                         :helpText=\"$tc('sw-cms.elements.netzp-blog6.config.numberofposts.help')\"\n                         v-model=\"element.config.numberOfPosts.value\" />\n\n        <sw-switch-field :label=\"$t('sw-cms.elements.netzp-blog6.config.noPagination')\"\n                         v-model=\"element.config.noPagination.value\" />\n\n        <sw-select-field v-if=\" ! isSpecificBlogPost\"\n                         :label=\"$tc('sw-cms.elements.netzp-blog6.config.sortorder.title')\"\n                         v-model=\"element.config.sortOrder.value\">\n            <option value=\"asc\">{{ $tc('sw-cms.elements.netzp-blog6.config.sortorder.asc') }}</option>\n            <option value=\"desc\">{{ $tc('sw-cms.elements.netzp-blog6.config.sortorder.desc') }}</option>\n        </sw-select-field>\n    </sw-container>\n\n    <sw-container columns=\"1fr 1fr\">\n        <sw-entity-single-select v-if=\"isSpecificBlogPost\"\n                                 :label=\"$t('sw-cms.elements.netzp-blog6.config.blogPost')\"\n                                 entity=\"s_plugin_netzp_blog\" :criteria=\"blogPostCriteria\"\n                                 valueProperty=\"id\" labelProperty=\"title\"\n                                 v-model=\"element.config.blogPost.value\">\n            <template #selection-label-property=\"{ item }\">\n                {{ item.title || item.translated.title }}\n            </template>\n            <template #result-label-property=\"{ item }\">\n                {{ item.title || item.translated.title }}\n            </template>\n        </sw-entity-single-select>\n    </sw-container>\n\n    <sw-container columns=\"1fr 1fr\" gap=\"20px\" v-if=\" ! isSpecificBlogPost\">\n        <sw-entity-multi-id-select :label=\"$t('sw-cms.elements.netzp-blog6.config.tags.label')\"\n                                   :placeholder=\"$tc('sw-cms.elements.netzp-blog6.config.tags.title')\"\n                                   :repository=\"repositoryTags\" :criteria=\"tagsCriteria\" :context=\"context\"\n                                   v-model=\"selectedTags\"\n                                   @change=\"onTagsChange\" />\n\n        <sw-single-select :label=\"$t('sw-cms.elements.netzp-blog6.config.author')\"\n                          :options=\"authors\" valueProperty=\"id\" labelProperty=\"name\"\n                          v-model=\"element.config.author.value\">\n\n            <template #selection-label-property=\"{ item }\">\n                {{ item.name || item.translated.name }}\n            </template>\n            <template #result-label-property=\"{ item }\">\n                {{ item.name || item.translated.name }}\n            </template>\n        </sw-single-select>\n    </sw-container>\n\n    <sw-container columns=\"1fr 1fr 1fr .5fr\" gap=\"20px\">\n        <sw-select-field :label=\"$tc('sw-cms.elements.netzp-blog6.config.layout.title')\"\n                         v-model=\"element.config.layout.value\">\n            <option value=\"cards\">{{ $tc('sw-cms.elements.netzp-blog6.config.layout.cards') }}</option>\n            <option v-if=\" ! isSpecificBlogPost\" value=\"slider\">{{ $tc('sw-cms.elements.netzp-blog6.config.layout.slider') }}</option>\n            <option value=\"list\">{{ $tc('sw-cms.elements.netzp-blog6.config.layout.list') }}</option>\n            <option value=\"tpl\">{{ $tc('sw-cms.elements.netzp-blog6.config.layout.template') }}</option>\n        </sw-select-field>\n\n        <sw-select-field v-if=\"element.config.layout.value != 'tpl'\" :label=\"$tc('sw-cms.elements.netzp-blog6.config.imageMode.title')\"\n                         v-model=\"element.config.imageMode.value\">\n            <option value=\"cover\">{{ $tc('sw-cms.elements.netzp-blog6.config.imageMode.cover') }}</option>\n            <option value=\"contain\">{{ $tc('sw-cms.elements.netzp-blog6.config.imageMode.contain') }}</option>\n        </sw-select-field>\n\n        <sw-colorpicker v-if=\"element.config.layout.value != 'tpl'\" :label=\"$tc('sw-cms.elements.netzp-blog6.config.backgroundColor')\"\n                        v-model=\"element.config.backgroundColor.value\" colorOutput=\"hex\" :zIndex=\"1001\" :alpha=\"false\">\n        </sw-colorpicker>\n\n        <sw-select-field v-if=\"element.config.layout.value != 'tpl'\"\n                         :label=\"$tc('sw-cms.elements.netzp-blog6-detail.config.titleTag.label')\"\n                         v-model=\"element.config.titleTag.value\">\n            <option value=\"h2\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.titleTag.h2') }}</option>\n            <option value=\"h3\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.titleTag.h3') }}</option>\n            <option value=\"h4\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.titleTag.h4') }}</option>\n            <option value=\"h5\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.titleTag.h5') }}</option>\n            <option value=\"h6\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.titleTag.h6') }}</option>\n            <option value=\"none\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.titleTag.none') }}</option>\n        </sw-select-field>\n    </sw-container>\n\n    <sw-container columns=\"1fr 1fr 1fr\" v-if=\" ! element.config.noPagination.value\">\n        <sw-switch-field :label=\"$t('sw-cms.elements.netzp-blog6.config.filterCategory')\" :noMarginTop=\"true\"\n                         v-model=\"element.config.filterCategory.value\" />\n        <sw-switch-field :label=\"$t('sw-cms.elements.netzp-blog6.config.filterTags')\" :noMarginTop=\"true\"\n                         v-model=\"element.config.filterTags.value\" />\n        <sw-switch-field :label=\"$t('sw-cms.elements.netzp-blog6.config.filterAuthor')\" :noMarginTop=\"true\"\n                         v-model=\"element.config.filterAuthor.value\" />\n    </sw-container>\n\n    <template v-if=\"element.config.layout.value == 'tpl'\">\n        <sw-code-editor :label=\"$t('sw-cms.elements.netzp-blog6.config.template.label')\"\n                        v-model=\"element.config.customTemplate.value\" />\n\n        <small v-html=\"$t('sw-cms.elements.netzp-blog6.config.template.help')\" />\n    </template>\n</div>\n";