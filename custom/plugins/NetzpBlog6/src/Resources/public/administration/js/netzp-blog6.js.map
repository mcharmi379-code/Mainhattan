export default "<div class=\"np-media-list-selection-item-v2\" :class=\"productImageClasses\">\n    <template v-if=\"!isPlaceholder\">\n        <sw-media-preview-v2\n            class=\"np-media-list-selection-item-v2__image\"\n            :source=\"sourceId\"\n            @click=\"$emit('click')\"\n            :hideTooltip=\"hideTooltip\">\n        </sw-media-preview-v2>\n        <sw-context-button v-if=\"!hideActions\" class=\"np-media-list-selection-item-v2__context-button\">\n            <sw-context-menu-item variant=\"danger\" @click=\"$emit('item-remove')\">{{ $tc('global.sw-media-list-selection-item-v2.buttonRemove') }}</sw-context-menu-item>\n        </sw-context-button>\n    </template>\n\n    <template v-else>\n            <sw-icon class=\"np-media-list-selection-item-v2__placeholder-icon\" :name=\"'regular-image'\" :small=\"true\"></sw-icon>\n    </template>\n</div>\n";