export default "<sw-page class=\"netzp-blog6-author-list\">\n    <template slot=\"smart-bar-header\">\n        <h2>\n            {{ $tc('sw-settings.index.title') }} <sw-icon name=\"regular-chevron-right-xs\" small /> {{ $tc('netzp-blog6-author.main.menuLabel') }}\n        </h2>\n    </template>\n\n    <template slot=\"smart-bar-actions\">\n        <sw-button variant=\"primary\" :routerLink=\"{ name: 'netzp.blog6.author.create' }\">\n            {{ $t('netzp-blog6-author.list.addButtonText') }}\n        </sw-button>\n    </template>\n    <template #language-switch>\n        <sw-language-switch @on-change=\"changeLanguage\"></sw-language-switch>\n    </template>\n\n    <template slot=\"content\">\n        <sw-entity-listing v-if=\"author\"\n                           :items=\"author\"\n                           :repository=\"repository\"\n                           :showSelection=\"false\"\n                           :columns=\"columns\"\n                           detailRoute=\"netzp.blog6.author.detail\">\n\n            <template #column-image=\"{ item }\">\n                <sw-media-preview-v2 :source=\"item.imageid ? item.imageid : null\"></sw-media-preview-v2>\n            </template>\n        </sw-entity-listing>\n    </template>\n</sw-page>\n";