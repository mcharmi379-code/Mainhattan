export default "<div class=\"sw-cms-el-netzp-blog6\">\n    <template v-if=\"element.config.layout.value == 'cards'\">\n        <sw-label variant=\"info\" size=\"small\" class=\"pull-right\">\n            {{ $tc('sw-cms.elements.netzp-blog6.cards') }}\n        </sw-label>\n        <div class=\"card\">\n            <div v-for=\"n in numberOfPosts\" :key=\"n\">\n                <div class=\"card-post\" :style=\"getCardStyle\">\n                    <img :src=\"'/administration/static/img/cms/preview_mountain_small.jpg' | asset\">\n\n                    <div class=\"card-body\">\n                        <h3>Blog post</h3>\n                        <div class=\"text-muted\">28.03.2020 | Category</div>\n                        <div class=\"btn\">{{ $tc('sw-cms.elements.netzp-blog6.more') }}</div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </template>\n\n    <template v-else-if=\"element.config.layout.value == 'slider'\">\n        <sw-label variant=\"info\" size=\"small\" class=\"pull-right\">\n            {{ $tc('sw-cms.elements.netzp-blog6.slider') }}\n        </sw-label>\n        <div class=\"slider-wrapper\">\n            <sw-icon name=\"regular-chevron-left\" size=\"25\" class=\"nav-left\" />\n            <sw-icon name=\"regular-chevron-right\" size=\"25\" class=\"nav-right\" />\n            <div class=\"slider\">\n                <div v-for=\"n in 3\" :key=\"n\">\n                    <div class=\"card-post\" :style=\"getCardStyle\">\n                        <img :src=\"'/administration/static/img/cms/preview_mountain_small.jpg' | asset\">\n\n                        <div class=\"card-body\">\n                            <h3>Blog post</h3>\n                            <div class=\"text-muted\">28.03.2020 | Category</div>\n                            <div class=\"btn\">{{ $tc('sw-cms.elements.netzp-blog6.more') }}</div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </template>\n\n    <template v-else-if=\"element.config.layout.value == 'tpl'\">\n        <sw-label variant=\"info\" size=\"small\" class=\"pull-right\">\n            {{ $tc('sw-cms.elements.netzp-blog6.template') }}\n        </sw-label>\n        <div v-html=\"element.config.customTemplate.value\" />\n    </template>\n\n    <template v-else>\n        <sw-label variant=\"info\" size=\"small\" class=\"pull-right\">\n            {{ $tc('sw-cms.elements.netzp-blog6.list') }}\n        </sw-label>\n        <div v-for=\"n in numberOfPosts\" :key=\"n\">\n            <div class=\"list\" :style=\"getCardStyle\">\n                <div class=\"left\">\n                    <h3>Blog post</h3>\n                    <div class=\"text-muted\">28.03.2020 | Category</div>\n                    <div class=\"btn\">{{ $tc('sw-cms.elements.netzp-blog6.more') }}</div>\n                </div>\n\n                <div class=\"right\">\n                    <img :src=\"'/administration/static/img/cms/preview_mountain_small.jpg' | asset\">\n                </div>\n            </div>\n        </div>\n    </template>\n</div>\n";