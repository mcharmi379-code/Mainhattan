export default "{% block sw_cms_mainhattan_listpage_image_text %}\n<div class=\"mainhattan-listpage-image-text\">\n    <div class=\"mainhattan-listpage-image-text-el--inner\">\n            <div class=\"sw-cms-el-image\" :class=\"displayModeClass\" :style=\"styles\">\n                {% block sw_cms_element_text %}\n                    <div class=\"sw-cms-el-text\">\n                        <div v-if=\"element.config.heading.source === 'mapped'\" class=\"sw-cms-el-text__mapping-preview content-editor\" v-html=\"$sanitize(demoValue)\"></div>\n                        <sw-text-editor\n                                v-else\n                                v-model=\"element.config.heading.value\"\n                                :disabled=\"disabled\"\n                                :allow-inline-data-mapping=\"true\"\n                                :is-inline-edit=\"true\"\n                                sanitize-input\n                                enable-transparent-background\n                                @blur=\"onBlur\"\n                                @input=\"onInput\"\n                        />\n                    </div>\n                {% endblock %}\n                {% block sw_cms_element_image_content %}\n                    <div class=\"mainhattan-listpage-image-text__bottom-image\">\n                        <img :src=\"mediaUrl\" :style=\"imgStyles\" alt=\"\">\n                    </div>\n                {% endblock %}\n            </div>\n    </div>\n</div>\n{% endblock %}";