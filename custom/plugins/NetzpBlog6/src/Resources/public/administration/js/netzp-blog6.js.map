export default "<div class=\"sw-cms-el-config-netzp-blog6-detail\">\n    <sw-select-field :label=\"$tc('sw-cms.elements.netzp-blog6-detail.config.part.label')\"\n                     v-model=\"element.config.part.value\"\n                     style=\"font-weight: bold\">\n        <option value=\"title\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.part.title') }}</option>\n        <option value=\"contents\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.part.contents') }}</option>\n        <option value=\"teaser\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.part.teaser') }}</option>\n        <option value=\"meta\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.part.meta') }}</option>\n        <option value=\"author\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.part.author') }}</option>\n        <option value=\"image\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.part.image') }}</option>\n        <option value=\"products\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.part.products') }}</option>\n        <option value=\"items\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.part.items') }}</option>\n        <option value=\"media\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.part.media') }}</option>\n        <option value=\"social\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.part.social') }}</option>\n        <option value=\"custom\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.part.custom') }}</option>\n    </sw-select-field>\n\n    <sw-select-field v-if=\"element.config.part.value === 'title'\"\n                     :label=\"$tc('sw-cms.elements.netzp-blog6-detail.config.titleTag.label')\"\n                     v-model=\"element.config.titleTag.value\">\n        <option value=\"h1\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.titleTag.h1') }}</option>\n        <option value=\"h2\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.titleTag.h2') }}</option>\n        <option value=\"h3\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.titleTag.h3') }}</option>\n        <option value=\"h4\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.titleTag.h4') }}</option>\n        <option value=\"h5\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.titleTag.h5') }}</option>\n        <option value=\"h6\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.titleTag.h6') }}</option>\n        <option value=\"none\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.titleTag.none') }}</option>\n    </sw-select-field>\n\n    <sw-container v-if=\"element.config.part.value === 'image'\" columns=\"1fr 1fr 1fr\" gap=\"20px\">\n        <sw-select-field :label=\"$tc('sw-cms.elements.netzp-blog6-detail.config.imageType.label')\"\n                         v-model=\"element.config.imageType.value\">\n            <option value=\"post\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.imageType.post') }}</option>\n            <option value=\"preview\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.imageType.preview') }}</option>\n        </sw-select-field>\n\n        <sw-select-field :label=\"$tc('sw-cms.elements.netzp-blog6-detail.config.imageMode.label')\"\n                         v-model=\"element.config.imageMode.value\">\n            <option value=\"full\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.imageMode.full') }}</option>\n            <option value=\"fullcontain\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.imageMode.fullcontain') }}</option>\n            <option value=\"small\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.imageMode.small') }}</option>\n            <option value=\"responsive\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.imageMode.responsive') }}</option>\n        </sw-select-field>\n\n        <sw-number-field v-if=\"element.config.imageMode.value != 'responsive'\"\n                         :label=\"$tc('sw-cms.elements.netzp-blog6-detail.config.height.label')\"\n                         numberType=\"int\" :min=\"1\" :max=\"100\" :step=\"1\" :value=\"12\"\n                         v-model=\"element.config.height.value\">\n        </sw-number-field>\n    </sw-container>\n\n    <sw-container v-if=\"element.config.part.value === 'meta'\" columns=\"1fr 1fr 1fr 1fr\" gap=\"20px\">\n        <sw-switch-field bordered :label=\"$tc('sw-cms.elements.netzp-blog6-detail.config.showDate')\"\n                         v-model=\"element.config.showDate.value\">\n        </sw-switch-field>\n\n        <sw-switch-field bordered :label=\"$tc('sw-cms.elements.netzp-blog6-detail.config.showAuthor')\"\n                         v-model=\"element.config.showAuthor.value\">\n        </sw-switch-field>\n\n        <sw-switch-field bordered :label=\"$tc('sw-cms.elements.netzp-blog6-detail.config.showCategory')\"\n                         v-model=\"element.config.showCategory.value\">\n        </sw-switch-field>\n\n        <sw-switch-field bordered :label=\"$tc('sw-cms.elements.netzp-blog6-detail.config.showTags')\"\n                         v-model=\"element.config.showTags.value\">\n        </sw-switch-field>\n    </sw-container>\n\n    <sw-container v-if=\"element.config.part.value === 'author'\" columns=\"1fr 1fr 1fr\" gap=\"20px\">\n        <sw-switch-field bordered :label=\"$tc('sw-cms.elements.netzp-blog6-detail.config.showAuthorAvatar')\"\n                         v-model=\"element.config.showAuthorAvatar.value\">\n        </sw-switch-field>\n\n        <sw-switch-field bordered :label=\"$tc('sw-cms.elements.netzp-blog6-detail.config.showAuthorName')\"\n                         v-model=\"element.config.showAuthorName.value\">\n        </sw-switch-field>\n\n        <sw-switch-field bordered :label=\"$tc('sw-cms.elements.netzp-blog6-detail.config.showAuthorBio')\"\n                         v-model=\"element.config.showAuthorBio.value\">\n        </sw-switch-field>\n    </sw-container>\n\n    <sw-container v-if=\"element.config.part.value === 'products'\" columns=\"1fr 1fr 1fr\" gap=\"20px\">\n        <sw-select-field :label=\"$tc('sw-cms.elements.netzp-blog6-detail.config.productLayout.label')\"\n                         v-model=\"element.config.productLayout.value\">\n            <option value=\"standard\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.productLayout.standard') }}</option>\n            <option value=\"image\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.productLayout.bigimage') }}</option>\n            <option value=\"minimal\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.productLayout.minimal') }}</option>\n        </sw-select-field>\n\n        <sw-select-field :label=\"$tc('sw-cms.elements.netzp-blog6-detail.config.productDisplayMode.label')\"\n                         v-model=\"element.config.productDisplayMode.value\">\n            <option value=\"cover\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.productDisplayMode.cover') }}</option>\n            <option value=\"contain\">{{ $tc('sw-cms.elements.netzp-blog6-detail.config.productDisplayMode.contain') }}</option>\n        </sw-select-field>\n\n        <sw-number-field :label=\"$tc('sw-cms.elements.netzp-blog6-detail.config.productMinWidth.label')\"\n                         numberType=\"int\" :min=\"200\" :max=\"800\" :step=\"1\" :value=\"12\"\n                         v-model=\"element.config.productMinWidth.value\">\n        </sw-number-field>\n    </sw-container>\n\n    <sw-container v-if=\"element.config.part.value === 'items'\" columns=\"1fr 1fr 1fr\" gap=\"20px\">\n        <sw-number-field :label=\"$tc('sw-cms.elements.netzp-blog6-detail.config.height.label')\"\n                         numberType=\"int\" :min=\"1\" :max=\"100\" :step=\"1\" :value=\"12\"\n                         v-model=\"element.config.height.value\">\n        </sw-number-field>\n    </sw-container>\n\n    <sw-container v-if=\"element.config.part.value === 'media'\" columns=\"1fr 1fr 1fr 1fr\" gap=\"20px\">\n        <sw-number-field :label=\"$tc('sw-cms.elements.netzp-blog6-detail.config.height.label')\"\n                         numberType=\"int\" :min=\"1\" :max=\"100\" :step=\"1\" :value=\"12\"\n                         v-model=\"element.config.height.value\">\n        </sw-number-field>\n\n        <sw-switch-field bordered :label=\"$tc('sw-cms.elements.netzp-blog6-detail.config.showGalleryCounter')\"\n                         v-model=\"element.config.showGalleryCounter.value\">\n        </sw-switch-field>\n\n        <sw-switch-field bordered :label=\"$tc('sw-cms.elements.netzp-blog6-detail.config.showGalleryCaption')\"\n                         v-model=\"element.config.showGalleryCaption.value\">\n        </sw-switch-field>\n\n        <sw-switch-field bordered :label=\"$tc('sw-cms.elements.netzp-blog6-detail.config.showThumbnailCaption')\"\n                         v-model=\"element.config.showThumbnailCaption.value\">\n        </sw-switch-field>\n    </sw-container>\n</div>\n";