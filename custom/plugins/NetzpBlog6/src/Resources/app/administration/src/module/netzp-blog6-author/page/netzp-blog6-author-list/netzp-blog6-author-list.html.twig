<sw-page class="netzp-blog6-author-list">
    <template #smart-bar-header>
        <h2>
            {{ $tc('sw-settings.index.title') }} <sw-icon name="regular-chevron-right-xs" small /> {{ $tc('netzp-blog6-author.main.menuLabel') }}
        </h2>
    </template>

    <template #smart-bar-actions>
        <sw-button variant="primary" :routerLink="{ name: 'netzp.blog6.author.create' }">
            {{ $t('netzp-blog6-author.list.addButtonText') }}
        </sw-button>
    </template>
    <template #language-switch>
        <sw-language-switch @on-change="changeLanguage" />
    </template>

    <template #content>
        <sw-entity-listing v-if="author"
                           :items="author"
                           :repository="repository"
                           :showSelection="false"
                           :columns="columns"
                           detailRoute="netzp.blog6.author.detail">

            <template #column-image="{ item }">
                <sw-media-preview-v2 :source="item.imageid ? item.imageid : null"></sw-media-preview-v2>
            </template>
        </sw-entity-listing>
    </template>
</sw-page>
