<div class="row">
{% set hasImages = false %}
{% for blogEntry in page.extensions.netzpSearch.blog.data %}
    {% if blogEntry.media %}
        {% set hasImages = true %}
    {% endif %}
{% endfor %}

{% for blogEntry in page.extensions.netzpSearch.blog.data %}
    <div class="col-12 col-md-6 col-lg-3 my-4">
        <div class="card h-100">
            {% if blogEntry.media.url %}
                <a href="{{ seoUrl('frontend.blog.post', {'postId': blogEntry.id}) }}">
                {% sw_thumbnails 'blog_image_search_thumbnail' with {
                    media: blogEntry.media,
                    attributes: {
                        'class': 'card-img-top',
                        'alt':   blogEntry.media.translated.alt ?: '',
                        'title': blogEntry.media.translated.title ?: ''
                    }
                } %}
                </a>
            {% elseif hasImages %}
                <div class="card-img-top"></div>
            {% endif %}

            <div class="card-body">
                <h3 class="card-title mt-3">
                    {{ blogEntry.getTitle }}
                </h3>
                <p class="card-text">
                    {{ blogEntry.getDescription }}
                </p>
                <h2>
                    <a href="{{ seoUrl('frontend.blog.post', {'postId': blogEntry.id}) }}"
                       class="btn btn-light">
                        {{ "netzp.blog.showPost"|trans }}
                    </a>
                </h2>
            </div>
        </div>
    </div>
{% endfor %}
</div>

