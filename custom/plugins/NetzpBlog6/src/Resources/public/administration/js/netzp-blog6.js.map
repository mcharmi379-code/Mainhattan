export default "<sw-page class=\"netzp-blog6-category-list\">\n    <template slot=\"smart-bar-header\">\n        <h2>\n            {{ $tc('sw-settings.index.title') }} <sw-icon name=\"regular-chevron-right-xs\" small /> {{ $tc('netzp-blog6-category.main.menuLabel') }}\n        </h2>\n    </template>\n\n    <template slot=\"smart-bar-actions\">\n        <sw-button variant=\"primary\" :routerLink=\"{ name: 'netzp.blog6.category.create' }\">\n            {{ $t('netzp-blog6-category.list.addButtonText') }}\n        </sw-button>\n    </template>\n    <template #language-switch>\n        <sw-language-switch @on-change=\"changeLanguage\"></sw-language-switch>\n    </template>\n\n    <template slot=\"content\">\n        <sw-entity-listing v-if=\"category\"\n                           :items=\"category\"\n                           :repository=\"repository\"\n                           :showSelection=\"false\"\n                           :columns=\"columns\"\n                           detailRoute=\"netzp.blog6.category.detail\">\n\n            <template #column-saleschannel=\"{ item }\">\n                <sw-label v-if=\"item.saleschannel\"\n                          variant=\"info\" size=\"default\" :ghost=\"true\">\n                    {{ item.saleschannel.name }}\n                </sw-label>\n            </template>\n\n            <template #column-customergroup=\"{ item }\">\n                <sw-label v-if=\"item.customergroup\"\n                          variant=\"info\" size=\"default\" :ghost=\"true\">\n                    {{ item.customergroup.name }}\n                </sw-label>\n            </template>\n\n            <template #column-onlyloggedin=\"{ item }\">\n                <sw-icon v-if=\"item.onlyloggedin\" name=\"regular-check-circle-s\" small />\n                <span v-else>&nbsp;</span>\n            </template>\n\n            <template #column-includeinrss=\"{ item }\">\n                <sw-icon v-if=\"item.includeinrss\" name=\"regular-checkmark-xs\" small class=\"is--active\" />\n                <sw-icon v-else name=\"regular-times-s\" small class=\"is--inactive\" />\n            </template>\n        </sw-entity-listing>\n    </template>\n</sw-page>\n";